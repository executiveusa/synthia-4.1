{
  "name": "cynthia-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Cynthia - Cinematic AI Experience Platform",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:web": "pnpm --filter web dev",
    "dev:clawdbot": "pnpm --filter clawdbot dev",
    "build": "pnpm --filter web build",
    "build:web": "pnpm --filter web build",
    "build:clawdbot": "pnpm --filter clawdbot build",
    "lint": "pnpm --filter web lint",
    "lint:web": "pnpm --filter web lint",
    "test": "pnpm -r test",
    "vercel:deploy": "cd apps/web && vercel --prod",
    "install:all": "pnpm install"
  },
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@8.15.0"
}
